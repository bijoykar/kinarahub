# =============================================================================
# Kinara Store Hub — Production .env template
# =============================================================================
# Copy this file to .env on your production server and fill in every value.
# Never commit the real .env to version control.
# =============================================================================

# --- Application ---------------------------------------------------------------
APP_ENV=production
APP_URL=https://yourdomain.com/kinarahub   # no trailing slash

# --- Database ------------------------------------------------------------------
# Use the 'kinarahub_app' user created by database/kinarahub.sql (Step 1).
DB_HOST=localhost         # or your remote DB host / private IP
DB_PORT=3306
DB_NAME=kinarahub
DB_USER=kinarahub_app
DB_PASS=StrongPass@123    # change to a strong password

# SSL (leave blank to disable — required for remote DB hosts)
DB_SSL_CA=               # /etc/ssl/certs/mysql-ca.pem

# --- JWT -----------------------------------------------------------------------
# Generate a random 64-char secret:  openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_SECRET
JWT_ACCESS_TTL=900        # 15 minutes
JWT_REFRESH_TTL=2592000   # 30 days

# --- Mail (SMTP) ---------------------------------------------------------------
MAIL_HOST=smtp.yourprovider.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASS=your_smtp_password
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="Kinara Store Hub"

# --- Seeded admin (used only on first deploy — change after seeding) ----------
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe@123
